#!/bin/bash

# ===== 权限检查：确保以 root 权限运行 =====
if [ "$EUID" -ne 0 ]
then
    # 不是 root，自动用 sudo 重新执行当前脚本
    # exec 会用新进程替换当前进程，$0 是脚本自身，$@ 是所有参数
    exec sudo "$0" "$@"
    # 如果 exec 失败才会执行到这里，返回错误码
    exit $?
fi

# ===== 文件锁配置，防止并发执行 =====
LOCK_FILE="/var/lock/recycle.lock"  # 锁文件路径
TIMEOUT=3                            # 获取锁的超时时间（秒）

# 设置信号捕获，脚本退出时自动清理锁文件
# EXIT: 正常退出  INT: Ctrl+C中断  TERM: kill信号  TSTP: Ctrl+Z挂起
trap 'rm -f "$LOCK_FILE"; exit' EXIT INT TERM TSTP

# 创建文件描述符 200 并打开锁文件（用于 flock 加锁）
exec 200>"$LOCK_FILE"
# 尝试获取文件锁，最多等待 $TIMEOUT 秒
if ! flock -w $TIMEOUT 200
then
    echo "错误: 回收站正忙" >&2
    exit 1
fi
# 将当前进程 PID 写入锁文件，方便调试
echo $$ > "$LOCK_FILE"

# 检查是否提供了参数
if [ $# -eq 0 ]
then
    echo "错误：需要至少一个参数"
    exit 1
fi

# ===== 初始化全局变量 =====
flag_r=false              # -r 选项标志，允许递归删除目录
trash="/trash"            # 回收站目录路径
delInfo="/trash/delInfo"  # 删除信息记录文件（格式：回收站文件名|原始路径）
mode="default"            # 操作模式：default(移入回收站) f(强制删除) R(恢复) s(查看) d(清空)

# 检查回收站目录是否存在
if [ ! -e "$trash" ]
then
    echo "错误：/trash 目录不存在，请联系管理员创建"
    exit 1
fi

# 检查删除信息记录文件是否存在
if [ ! -e "$delInfo" ]
then
    echo "错误：/trash/delInfo 文件不存在，请联系管理员创建"
    exit 1
fi

# 检查文件存在性以及权限
# 返回值：0-属于当前用户  1-文件不存在  2-权限不足（属于其他用户）
check_owner()
{
    local file="$1"

    # 检查文件是否真实存在（包括损坏的符号链接）
    # -e 检查目标存在，-L 检查是否为符号链接本身
    if [ ! -e "$file" ] && [ ! -L "$file" ]
    then
        return 1
    fi
    
    # 获取实际操作用户：优先使用 SUDO_USER（sudo前的用户），否则用 whoami
    local current_user="${SUDO_USER:-$(whoami)}"
    # 获取文件的所有者名称
    local file_owner=$(stat -c '%U' "$file" 2>/dev/null)
    
    # 比较文件所有者和当前用户
    if [ "$file_owner" != "$current_user" ]
    then
        return 2
    fi

    return 0
}

# 默认删除模式（将文件移入回收站）
default_mode()
{

    for file in "$@"
    do
        # 检查文件所有权
        check_owner "$file"
        local code=$?
        case ${code} in
            0)
                # 权限正常，继续执行
                ;;
            1)
                echo "错误：文件不存在：${file}" >&2
                continue
                ;;
            2)
                echo "错误：权限不足：${file}" >&2
                continue
                ;;
            *)
                echo "错误：未知错误($code)" >&2
                continue
                ;;
        esac

        # 如果是目录且未使用 -r 标志，拒绝删除
        if [ -d "$file" ] && [ "$flag_r" != "true" ]
        then
            echo "错误：默认无法删除目录，请尝试使用-r" >&2
            continue
        fi

        # 获取文件基本信息
        local src_name="$(basename "${file}")"          # 文件名（不含路径）
        local src_path="$(realpath -s "${file}")"       # 文件绝对路径
        local target_name="${src_name}"                  # 回收站中的文件名
        local target_path="${trash}/${src_name}"         # 回收站中的完整路径
        
        # 处理重名文件：添加时间戳后缀避免覆盖已有文件，实现多版本共存
		# 同时不全部添加时间戳是因为可以马上区分最开始的文件
        while [ -e "$target_path" ]
        do
            target_name="${src_name}_$(date +%s)"
            target_path="${trash}/${target_name}"
        done

 
        if mv "$file" "$target_path"
        then
            # 记录删除信息：回收站文件名|原始路径
            echo "${target_name}|${src_path}" >> "${delInfo}"
        else
            echo "错误: 删除文件失败: ${file}" >&2
        fi
    done
}

# 强制删除模式（永久删除，不进回收站）
f_mode()
{
    for file in "$@"
    do
        # 检查文件所有权
        check_owner "$file"
        local code=$?
        case ${code} in
            0)
                ;;
            1)
                echo "错误：文件不存在：${file}" >&2
                continue
                ;;
            2)
                echo "错误：权限不足：${file}" >&2
                continue
                ;;
            *)
                echo "错误：未知错误($code)" >&2
                continue
                ;;
        esac

        # 目录需要 -r 标志才能强制删除
        if [ -d "$file" ] && [ "$flag_r" != "true" ]
        then
            echo "错误：默认无法删除目录，请尝试使用-r" >&2
            continue
        fi

        # 获取文件绝对路径
        local src_path="$(realpath -s "${file}")"

        # 使用 rm -rf 永久删除（不经过回收站）
        if ! rm -rf "${src_path}"
        then
            echo "错误: 删除文件失败: ${file}" >&2
        fi
    done
}

# 恢复模式（从回收站恢复文件）
R_mode()
{
    # 保存当前终端列数并设置为1，优化 select 菜单显示
	# 如果不设置，经测试会出现1 3 在同一行这样的问题
    OLD_COLUMNS="${COLUMNS}"
    COLUMNS=1
    
    for file in "$@"
    do
        local src_name="$(basename "${file}")"   # 用户输入的文件名
        local target_name="${src_name}"
        local filtered_result=()

        # 从 delInfo 中查找匹配的文件记录
        # awk: 以 | 分隔，$1 是回收站文件名，匹配以 target 开头的行，index比对返回位置结果
		# 不使用grep，因为grep会解析正则表达式，导致读取出现问题
        # tac: 反转顺序，最近删除的排在前面
		# mapfile: 将命令输出按行读入数组
		# -t: 去掉每行末尾的换行符
		# < <(...): 进程替换，将命令输出作为标准输入
        mapfile -t all_result < <(
            awk -F'|' -v target="${target_name}" 'index($1, target) == 1' "$delInfo" | tac
        )

        # 过滤：只保留属于当前用户的文件
        for item in "${all_result[@]}"
        do
			# 临时设置分隔符为|用来切分后读入变量
            IFS='|' read -r target_name ori_path <<< "$item"
            if check_owner "$trash/$target_name"
            then
                filtered_result+=("$item")
            fi
        done
        
        # 使用过滤后的结果
        local result=("${filtered_result[@]}")

        # 检查是否找到匹配文件（数量不为0）
        if [ ${#result[@]} -eq 0 ]
        then
            echo "错误: /trash 没有匹配文件: ${src_name}"
            continue
        fi

        # 准备显示数据
        local display=()       # 用于 select 菜单的显示数组
        local -a temp_data=()  # 临时存储格式化前的数据
        local max_size=0       # 文件大小列的最大宽度
        local max_name=0       # 文件名列的最大宽度

        # 遍历匹配结果，收集文件信息用于显示
        for dis in "${result[@]}"
        do
            IFS='|' read -r target_name ori_path <<< "${dis}"
            local del_time="未知时间"
            local file_size="未知大小"
            local type_char="?"    # 文件类型字符：d目录 -文件 l链接
            
            # 如果文件在回收站中存在（包括符号链接）
            if [ -e "$trash/$target_name" ] || [ -L "$trash/$target_name" ]
            then
                # 获取文件修改时间（即删除时间），是能被mv修改的最后状态时间%z ctime
				# cut -d 指定分隔符为.，去掉小数点后取前面部分，-f就是按字段划分
                del_time="$(stat -c '%z' "$trash/$target_name" 2>/dev/null | cut -d'.' -f1)"
                del_time="${del_time:-未知时间}"
                # 获取文件大小
				# du -s 统计总数据，-h 自动转换单位
				# cut 不指定分隔符因为du的输出分隔符就是cut的默认分隔符\t
                file_size="$(du -sh "$trash/$target_name" 2>/dev/null | cut -f1)"
                # 获取文件类型第一个字符
				# cut -c 按位置取，获取第一个位置的字符 -c1
                type_char=$(ls -ld "$trash/$target_name" 2>/dev/null | cut -c1)
            fi
            
            # 用 | 分隔存储临时数据
            temp_data+=("${del_time}|${type_char}|${file_size}|${target_name}|${ori_path}")
            
            # 计算列宽，用于后续对齐显示
			# wc -c 统计字数，即获取宽度
            local size_len=$(echo -n "$file_size" | wc -c)
            local name_len=$(echo -n "$target_name" | wc -c)
            
            # 更新最大宽度（+1 是为了列之间留空格）
            [ $size_len -gt $max_size ] && max_size=$((size_len + 1))
            [ $name_len -gt $max_name ] && max_name=$((name_len + 1))
        done
        
        echo "总计 ${#result[@]}"

        # 格式化显示数据（使用 printf 对齐各列）
        for data in "${temp_data[@]}"
        do
            IFS='|' read -r del_time type_char file_size target_name ori_path <<< "$data"
            # 格式：时间 类型 大小(对齐) 文件名(对齐) 原始路径（最后一列不用对齐末尾）
            display+=("$del_time  $type_char  $(printf "%-${max_size}s %-${max_name}s %s" "$file_size" "$target_name" "$ori_path")")
        done

        # 创建交互式选择菜单
		# PS3 就是输入前面的那串文字，默认是#? 
        PS3="选择恢复版本(编号): "
        select item in "${display[@]}" "取消"
        do
            if [ "$item" == "取消" ]
            then
                break
            elif [ -n "$item" ]
            then
                # 计算用户在结果数组中的索引
				# select从1开始计数（REPLY），所以索引-1
                local index=$((REPLY - 1))
                IFS='|' read -r target_name ori_path <<< "${result[$index]}"

                # 检查原始路径是否已存在文件
                check_owner "${ori_path}"
                local code=$?
                case ${code} in
                    0)
                        # 目标文件已存在，询问是否覆盖
                        echo "警告: 目标文件已存在: ${ori_path}"
                        read -p "是否覆盖？(y/n): " confirm
                        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]
                        then
                            echo "操作已取消"
                            continue
                        fi
                        ;;
                    1)
                        # 目标路径不存在，可以直接恢复
                        ;;
                    2)
                        # 目标文件存在但权限不足
                        echo "错误：目标文件已存在，且权限不足: ${ori_path}" >&2
                        continue
                        ;;
                    *)
                        echo "错误：未知错误($code)" >&2
                        continue
                        ;;
                esac
                
                # 执行恢复：将文件从回收站移回原始路径
                if mv "$trash/$target_name" "$ori_path"
                then
                    # 从 delInfo 记录文件中删除对应条目
					# sed -i 直接修改行，不输出，d是删除
					# \;指定分隔符，因为；不常用，默认是/但是记录有/就换掉了
                    sudo sed -i "\;${target_name}|${ori_path};d" "$delInfo"
                else
                    echo "错误: 未知错误($?), 恢复失败: ${ori_path}"
                fi
                break
            else
                echo "无效输入，请重新选择"
            fi
        done
    done
    
    # 恢复原来的终端列数设置
    COLUMNS=$OLD_COLUMNS
}

# 查看模式（浏览回收站中文件的内容)
s_mode()
{
    OLD_COLUMNS="${COLUMNS}"
    COLUMNS=1
    
    local filtered_result=()

    # 读取 delInfo 并反转顺序（最近删除的在前）
    mapfile -t all_result < <(tac "$delInfo")

    # 过滤：只保留属于当前用户的文件
    for item in "${all_result[@]}"
    do
        IFS='|' read -r target_name ori_path <<< "$item"
        if check_owner "$trash/$target_name"
        then
            filtered_result+=("$item")
        fi
    done
    
    local result=("${filtered_result[@]}")

    # 检查回收站是否为空
    if [ ${#result[@]} -eq 0 ]
    then
        echo "回收站为空"
        return 0
    fi

    # 准备显示数据（逻辑与 R_mode 相同）
    local display=()
    local -a temp_data=()
    local max_size=0
    local max_name=0

    for dis in "${result[@]}"
    do
        IFS='|' read -r target_name ori_path <<< "${dis}"
        local del_time="未知时间"
        local file_size="未知大小"
        local type_char="?"
        if [ -e "$trash/$target_name" ] || [ -L "$trash/$target_name" ]
        then
            del_time="$(stat -c '%z' "$trash/$target_name" 2>/dev/null | cut -d'.' -f1)"
            del_time="${del_time:-未知时间}"
            file_size="$(du -sh "$trash/$target_name" 2>/dev/null | cut -f1)"
            type_char=$(ls -ld "$trash/$target_name" 2>/dev/null | cut -c1)
        fi
        temp_data+=("${del_time}|${type_char}|${file_size}|${target_name}|${ori_path}")
        local size_len=$(echo -n "$file_size" | wc -c)
        local name_len=$(echo -n "$target_name" | wc -c)
        
        [ $size_len -gt $max_size ] && max_size=$((size_len + 1))
        [ $name_len -gt $max_name ] && max_name=$((name_len + 1))
    done
    
    echo "总计 ${#result[@]}"

    # 格式化显示数据
    for data in "${temp_data[@]}"
    do
        IFS='|' read -r del_time type_char file_size target_name ori_path <<< "$data"
        display+=("$del_time  $type_char  $(printf "%-${max_size}s %-${max_name}s %s" "$file_size" "$target_name"  "$ori_path")")
    done

    # 交互式选择文件查看内容
    PS3="选择文件(编号): "
    select item in "${display[@]}" "取消"
    do
        if [[ "$item" == "取消" ]]
        then
            break
        elif [[ -n "$item" ]]
        then
            local index=$((REPLY - 1))
            IFS='|' read -r target_name ori_path <<< "${result[$index]}"
            target_path="${trash}/${target_name}"

            # 根据文件类型选择不同的查看方式
            if [ -d "${target_path}" ]
            then
                # 目录：使用 ls -la 列出内容，通过 less 分页
                if ! ls -la "${target_path}" | less
                then
                    echo "错误: 无法显示文件内容: ${target_name}"
                fi
                continue
            else
                # 普通文件：使用 less 查看内容
                if ! less "$trash/$target_name"
                then
                    echo "错误: 无法显示文件内容: ${target_name}"
                fi
                continue
            fi
        else
            echo "无效输入，请重新选择"
        fi
    done

    COLUMNS=$OLD_COLUMNS
}

# 清空模式（永久删除回收站中当前用户的所有文件）
d_mode()
{
    # 二次确认，防止误操作
    echo "警告: 这将永久删除回收站中您的所有文件！"
    read -p "确认清空？(y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]
    then
        echo "操作已取消"
        return 0
    fi

    # 读取所有删除记录
    mapfile -t all_result < <(tac "$delInfo")

    local filtered_result=()

    # 过滤：只保留当前用户的文件
    for item in "${all_result[@]}"
    do
        IFS='|' read -r target_name ori_path <<< "$item"
        if check_owner "$trash/$target_name"
        then
            filtered_result+=("$item")
        fi
    done
    
    local result=("${filtered_result[@]}")

    # 如果已经为空则直接返回
    if [ ${#result[@]} -eq 0 ]
    then
        echo "回收站已为空"
        return 0
    fi

    # 逐个永久删除文件并清理记录
    for dis in "${result[@]}"
    do
        IFS='|' read -r target_name ori_path <<< "${dis}"
        if rm -rf "$trash/$target_name"
        then
            # 从记录文件中删除对应条目
            sudo sed -i "\;${target_name}|${ori_path};d" "$delInfo"
        else
            echo "错误: 删除文件失败: ${target_name}"
            continue
        fi
    done
}

# 命令行参数解析
# 支持的选项：f(强制删除) r(递归) R(恢复) s(查看) d(清空)
while getopts "frRsd" opt
do
    case $opt in
        f)
            # -f: 强制永久删除模式
            if [ "$mode" != "default" ]
            then
                echo "错误: -f, -R, -s, -d 参数不支持混用"
                exit 1
            fi
            mode="f"
            ;;
        r)
            # -r: 递归标志，允许删除目录
            flag_r=true
            ;;
        R)
            # -R: 恢复模式
            if [ "$mode" != "default" ]
            then
                echo "错误: -f, -R, -s, -d 参数不支持混用"
                exit 1
            fi
            mode="R"
            ;;
        s)
            # -s: 查看回收站模式
            if [ "$mode" != "default" ]
            then
                echo "错误: -f, -R, -s,-d 参数不支持混用"
                exit 1
            fi
            mode="s"
            ;;
        d)
            # -d: 清空回收站模式
            if [ "$mode" != "default" ]
            then
                echo "错误: -f, -R, -s, -d 参数不支持混用"
                exit 1
            fi
            mode="d"
            ;;
        *)
            # 未知选项
            echo "未知的选项: -${opt}"
            exit 1
            ;;
    esac
done

# 移除已处理的选项参数，剩下的 $@ 为文件名参数
shift $((OPTIND - 1))

# 根据解析到的模式执行对应的函数
case "$mode" in
    R)
        R_mode "$@"     # 恢复文件
        ;;
    f)
        f_mode "$@"     # 强制删除
        ;;
    s)
        s_mode          # 查看回收站
        ;;
    d)
        d_mode          # 清空回收站
        ;;
    default)
        default_mode "$@"  # 默认：移入回收站
        ;;
esac