#!/bin/bash
if [ $# -eq 0 ]
then
	echo "error: need at least 1 arg"
	exit 1
fi

flag_f=false
flag_r=false
flag_R=false
trash="/trash"
delInfo="/trash/delInfo"
mode="default"
if [ ! -e "$trash" ]; then
    echo "error: /trash not exists, contact admin"
    exit 1
fi

if [ ! -e "$delInfo" ]; then
    echo "error: /trash/delInfo not exists, contact admin"
    exit 1
fi
check_owner() {
    local file="$1"
    local current_user=$(whoami)
    local file_owner=$(stat -c '%U' "$file" 2>/dev/null)

	if [ ! -e "$file" ]; then
        echo "error: file not found: $file"
        return 2
    fi
    
    if [ "$file_owner" != "$current_user" ]; then
        return 1
    fi
    return 0
}
default_mode(){
	for file in "$@"
	do
		if ! check_owner "$file"
		then
			echo "error: permission denied"
			continue
		fi

		if [ -d "$file" ] && [ "$flag_r" != "true" ]; then
            echo "can't junk dir, use -r instead"
            continue
        fi
		local src_name="$(basename "${file}")"
		local src_path="$(realpath -s "${file}")"
		local target_name="${src_name}"
		local target_path="$trash/${src_name}"
		
        while [ -e "$target_path" ]
		do
			target_name="${src_name}_$(date +%s)"
            target_path="${trash}/${target_name}"
        done

        if mv "$file" "$target_path"
		then
            echo "${target_name}|${src_path}" >> "${delInfo}"
        else
            echo "error: failed to junk: $file"
        fi
	done
}

f_mode(){
	for file in "$@"
	do
		if ! check_owner "$file"
		then
			echo "error: permission denied"
			continue
		fi
		if [ -d "$file" ] && [ "$flag_r" != "true" ]; then
            echo "can't junk dir, use -r instead"
            continue
        fi

		local src_path="$(realpath -s "${file}")"

		if ! rm -rf "${src_path}"
		then
			echo "error: failed to junk: $file"
		fi

	done
}

R_mode(){
	OLD_COLUMNS="${COLUMNS}"
	COLUMNS=1
	for file in "$@"
	do
		local src_name="$(basename "${file}")"
		local target_name="${src_name}"
		local target_path="$trash/${src_name}"
		local filtered_result=()

		mapfile -t all_result < <(
        grep "^${target_name}" "$delInfo" | tac )

		for item in "${all_result[@]}"; do
			IFS='|' read -r target_name ori_path <<< "$item"
			if [ -e "$trash/$target_name" ] && check_owner "$trash/$target_name"; then
				filtered_result+=("$item")
			fi
		done
		
		# 用过滤后的结果替换
		result=("${filtered_result[@]}")

		if [ ${#result[@]} -eq 0 ]
		then
        	echo "no such file in trash"
        	continue
    	fi

		display=()

		for dis in "${result[@]}"
		do
			IFS='|' read -r target_name ori_path <<< "${dis}"
			local del_time="未知时间"
            if [ -e "$trash/$target_name" ]
			then
                del_time="$(stat -c '%y' "$trash/$target_name" 2>/dev/null | cut -d'.' -f1)"
            fi
            display+=("${target_name} ${ori_path} ${del_time}")
		done

		PS3="选择恢复版本 (输入编号): "
		select item in "${display[@]}" "cancel"
		do
			if [[ "$item" == "cancel" ]]
			then
				break
			elif [[ -n "$item" ]]
			then
				local index=$((REPLY - 1))
				IFS='|' read -r target_name ori_path <<< "${result[$index]}"

				# if [ -e "${ori_path}" ]
				# then
				# 	echo "error: 已存在同名文件"
				# 	continue
				# fi

				if [ -e "${ori_path}" ] || [ -d "${ori_path}" ]
				then
					echo "warning: 目标路径已存在: $ori_path"
					read -p "是否覆盖？(y/n): " confirm
					if [[ "$confirm" != "y" && "$confirm" != "Y" ]]
					then
						echo "操作已取消。"
						continue
					fi
				fi
				
				if mv "$trash/$target_name" "$ori_path"
				then
					sed -i "\#${target_name}|${ori_path}#d" "$delInfo"
					echo "成功恢复: $ori_path"
				else
					echo "恢复失败！请检查目标路径是否存在。"
				fi
				break
			else
				echo "无效输入，请重新选择。"
			fi
		done
    done
	COLUMNS=$OLD_COLUMNS
}

s_mode(){
	OLD_COLUMNS="${COLUMNS}"
	COLUMNS=1
	
	local filtered_result=()

	mapfile -t all_result < <(
	tac "$delInfo" )

	for item in "${all_result[@]}"; do
		IFS='|' read -r target_name ori_path <<< "$item"
		if [ -e "$trash/$target_name" ] && check_owner "$trash/$target_name"; then
			filtered_result+=("$item")
		fi
	done
	
	# 用过滤后的结果替换
	result=("${filtered_result[@]}")

	if [ ${#result[@]} -eq 0 ]
	then
		echo "no file in trash"
		return 1
	fi

	display=()

	for dis in "${result[@]}"
	do
		IFS='|' read -r target_name ori_path <<< "${dis}"
		local del_time="未知时间"
		local file_size="未知大小"
		if [ -e "$trash/$target_name" ]
		then
			del_time="$(stat -c '%y' "$trash/$target_name" 2>/dev/null | cut -d'.' -f1)"
			file_size="$(du -sh "$trash/$target_name" 2>/dev/null | cut -f1)"
		fi
		display+=("${del_time} ${file_size} ${target_name} ${ori_path}")
	done
	echo "总计 ${#result[@]}"

	PS3="选择文件(输入编号): "
	select item in "${display[@]}" "cancel"
	do
		if [[ "$item" == "cancel" ]]
		then
			break
		elif [[ -n "$item" ]]
		then
			local index=$((REPLY - 1))
			IFS='|' read -r target_name ori_path <<< "${result[$index]}"
			target_path="${trash}/${target_name}"

			if [ -d "${target_path}" ]
			then
				if ! ls -la  "${target_path}" | less
				then
					echo "error: can't print content of ${target_name}"
				fi
				continue
			else
				if ! less "$trash/$target_name"
				then
					echo "error: can't print content of ${target_name}"
				fi
				continue
			fi
		else
			echo "无效输入，请重新选择。"
		fi
	done

	COLUMNS=$OLD_COLUMNS
}

d_mode(){

	echo "警告: 这将永久删除回收站中您的所有文件！"
    read -p "确认清空？(y/N): " confirm
    
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "操作已取消"
        return 0
    fi

	mapfile -t all_result < <(
	tac "$delInfo" )

	local filtered_result=()

	for item in "${all_result[@]}"; do
		IFS='|' read -r target_name ori_path <<< "$item"
		if [ -e "$trash/$target_name" ] && check_owner "$trash/$target_name"; then
			filtered_result+=("$item")
		fi
	done
	
	# 用过滤后的结果替换
	result=("${filtered_result[@]}")

	if [ ${#result[@]} -eq 0 ]
	then
	 	echo "回收站已为空"
        return 0
	fi

	for dis in "${result[@]}"
	do
		IFS='|' read -r target_name ori_path <<< "${dis}"
		if rm -rf "$trash/$target_name"
			then
				sed -i "\#${target_name}|${ori_path}#d" "$delInfo"
			else
				echo "error: 删除文件失败: ${target_name}"
				continue
			fi
	done

}
while getopts "frRsd" opt; do
    case $opt in
        f) 
            if [ "$mode" != "default" ]; then
                echo "error: -f, -R, -s and default mode are mutually exclusive"
                exit 1
            fi
            mode="f" 
            ;;
        r) flag_r=true ;;
        R) 
            if [ "$mode" != "default" ]; then
                echo "error: -f, -R, -s and default mode are mutually exclusive"
                exit 1
            fi
            mode="R" 
            ;;
		s)	if [ "$mode" != "default" ]; then
                echo "error: -f, -R, -s and default mode are mutually exclusive"
                exit 1
            fi
            mode="s" 
            ;;
		d)	if [ "$mode" != "default" ]; then
                echo "error: -f, -R, -s and default mode are mutually exclusive"
                exit 1
            fi
            mode="d" 
            ;;
        *) 
            echo "unknown option: -$opt"
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

case "$mode" in
    R) R_mode "$@" ;;
    f) f_mode "$@" ;;
	s) s_mode ;;
	d) d_mode ;;
    default) default_mode "$@" ;;
esac
	
		
	

