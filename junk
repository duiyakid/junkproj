#!/bin/bash

if [ "$EUID" -ne 0 ]; then
    # 不是 root，自动用 sudo 重新执行
    exec sudo "$0" "$@"
    exit $?
fi

LOCK_FILE="/var/lock/recycle.lock"
TIMEOUT=3

trap 'rm -f "$LOCK_FILE"; exit' EXIT INT TERM TSTP

exec 200>"$LOCK_FILE"
if ! flock -w $TIMEOUT 200; then
    echo "错误: 回收站正忙" >&2
    exit 1
fi
echo $$ > "$LOCK_FILE"

if [ $# -eq 0 ]
then
	echo "错误：需要至少一个参数"
	exit 1
fi





# 判断参数
flag_r=false
flag_R=false
trash="/trash"
delInfo="/trash/delInfo"
mode="default"

if [ ! -e "$trash" ]; then
    echo "错误：/trash 目录不存在，请联系管理员创建"
    exit 1
fi

if [ ! -e "$delInfo" ]; then
    echo "错误：/trash/delInfo 文件不存在，请联系管理员创建"
    exit 1
fi

check_owner() {
	local file="$1"

	if [ ! -e "$file" ] && [ ! -L "$file" ]; then
        return 1
    fi
    
    local current_user="${SUDO_USER:-$(whoami)}"
    local file_owner=$(stat -c '%U' "$file" 2>/dev/null)
    
    if [ "$file_owner" != "$current_user" ]; then
        return 2
    fi

    return 0
}
default_mode(){
	for file in "$@"
	do
		check_owner "$file"
		local code=$?
		case ${code} in
		0) 
			;;
		1)
			echo "错误：文件不存在：${file}" >&2
			continue
			;;
		2)
			echo "错误：权限不足：${file}" >&2
			continue
			;;
		*)
			echo "错误：未知错误($code)" >&2
			continue
			;;
		esac

		if [ -d "$file" ] && [ "$flag_r" != "true" ]
		then
            echo "错误：默认无法删除目录，请尝试使用-r" >&2
            continue
        fi

		local src_name="$(basename "${file}")"
		local src_path="$(realpath -s "${file}")"
		local target_name="${src_name}"
		local target_path="${trash}/${src_name}"
		
		# 对于重名文件，添加时间戳后缀避免覆盖
        while [ -e "$target_path" ]
		do
			target_name="${src_name}_$(date +%s)"
            target_path="${trash}/${target_name}"
        done

        if mv "$file" "$target_path"
		then
            echo "${target_name}|${src_path}" >> "${delInfo}"
        else
            echo "错误: 删除文件失败: ${file}" >&2
        fi
	done
}

f_mode(){
	for file in "$@"
	do
		check_owner "$file"
		local code=$?
		case ${code} in
		0) 
			;;
		1)
			echo "错误：文件不存在：${file}" >&2
			continue
			;;
		2)
			echo "错误：权限不足：${file}" >&2
			continue
			;;
		*)
			echo "错误：未知错误($code)" >&2
			continue
			;;
		esac

		if [ -d "$file" ] && [ "$flag_r" != "true" ]
		then
            echo "错误：默认无法删除目录，请尝试使用-r" >&2
            continue
        fi

		local src_path="$(realpath -s "${file}")"

		if ! rm -rf "${src_path}"
		then
			echo "错误: 删除文件失败: ${file}" >&2
		fi

	done
}

R_mode(){
	OLD_COLUMNS="${COLUMNS}"
	COLUMNS=1
	for file in "$@"
	do
		local src_name="$(basename "${file}")"
		local target_name="${src_name}"
		# local target_path="$trash/${src_name}"
		local filtered_result=()

		mapfile -t all_result < <(
        # grep "^${target_name}" "$delInfo" | tac )
		awk -F'|' -v target="${target_name}" 'index($1, target) == 1' "$delInfo" | tac )

		for item in "${all_result[@]}"; do
			IFS='|' read -r target_name ori_path <<< "$item"
			if check_owner "$trash/$target_name"
			then
				filtered_result+=("$item")
			fi
		done
		
		# 用过滤后的结果替换
		local result=("${filtered_result[@]}")

		if [ ${#result[@]} -eq 0 ]
		then
        	echo "错误: /trash 没有匹配文件: ${src_name}"
        	continue
    	fi

		local display=()
		local -a temp_data=()
		local max_size=0 max_name=0

		for dis in "${result[@]}"
		do
			IFS='|' read -r target_name ori_path <<< "${dis}"
			local del_time="未知时间"
			local file_size="未知大小"
			if [ -e "$trash/$target_name" ] || [ -L "$trash/$target_name" ]
			then
				del_time="$(stat -c '%y' "$trash/$target_name" 2>/dev/null | cut -d'.' -f1)"
				del_time="${del_time:-未知时间}"
				file_size="$(du -sh "$trash/$target_name" 2>/dev/null | cut -f1)"
			fi
			temp_data+=("${del_time}|${file_size}|${target_name}|${ori_path}")
			local size_len=$(echo -n "$file_size" | wc -c)
			local name_len=$(echo -n "$target_name" | wc -c)
			
			# [ $size_len -gt $max_size ] && max_size=$size_len+1
			# [ $name_len -gt $max_name ] && max_name=$name_len+1
			[ $size_len -gt $max_size ] && max_size=$((size_len + 1))
			[ $name_len -gt $max_name ] && max_name=$((name_len + 1))
			# display+=("${del_time} ${file_size} ${target_name} ${ori_path}")
		done
		echo "总计 ${#result[@]}"
		# 设置大小和文件名的最小宽度
		# [ $max_size -lt 8 ] && max_size=5    # 大小列最小8个字符
		# [ $max_name -lt 10 ] && max_name=3  # 文件名列最小10个字符

		for data in "${temp_data[@]}"
		do
			IFS='|' read -r del_time file_size target_name ori_path <<< "$data"
			# 时间列直接原样输出，大小和文件名列对齐
			display+=("$del_time  $(printf "%-${max_size}s %-${max_name}s %s" "$file_size" "$target_name" "$ori_path")")
		done

		PS3="选择恢复版本(编号): "
		select item in "${display[@]}" "取消"
		do
			if [ "$item" == "取消" ]
			then
				break
			elif [ -n "$item" ]
			then
				local index=$((REPLY - 1))
				IFS='|' read -r target_name ori_path <<< "${result[$index]}"

				check_owner "${ori_path}"
				local code=$?
				case ${code} in
				0) 
					echo "警告: 目标文件已存在: ${ori_path}"
					read -p "是否覆盖？(y/n): " confirm
					if [[ "$confirm" != "y" && "$confirm" != "Y" ]]
					then
						echo "操作已取消"
						continue
					fi
					;;
				1)
					;;
				2)
					echo "错误：目标文件已存在，且权限不足: ${ori_path}" >&2
					continue
					;;
				*)
					echo "错误：未知错误($code)" >&2
					continue
					;;
				esac
				
				if mv "$trash/$target_name" "$ori_path"
				then
					sudo sed -i "\#${target_name}|${ori_path}#d" "$delInfo"
				else
					echo "错误: 未知错误($?), 恢复失败: ${ori_path}"
				fi
				break
			else
				echo "无效输入，请重新选择"
			fi
		done
    done
	COLUMNS=$OLD_COLUMNS
}

s_mode(){
	OLD_COLUMNS="${COLUMNS}"
	COLUMNS=1
	
	local filtered_result=()

	mapfile -t all_result < <(
	tac "$delInfo" )

	for item in "${all_result[@]}"
	do
		IFS='|' read -r target_name ori_path <<< "$item"
		if check_owner "$trash/$target_name"
		then
			filtered_result+=("$item")
		fi
	done
	
	# 用过滤后的结果替换
	local result=("${filtered_result[@]}")

	if [ ${#result[@]} -eq 0 ]
	then
		echo "回收站为空"
		return 0
	fi

	local display=()
	local -a temp_data=()
	local max_size=0 max_name=0

	for dis in "${result[@]}"
	do
		IFS='|' read -r target_name ori_path <<< "${dis}"
		local del_time="未知时间"
		local file_size="未知大小"
		if [ -e "$trash/$target_name" ] || [ -L "$trash/$target_name" ]
		then
			del_time="$(stat -c '%y' "$trash/$target_name" 2>/dev/null | cut -d'.' -f1)"
			del_time="${del_time:-未知时间}"
			file_size="$(du -sh "$trash/$target_name" 2>/dev/null | cut -f1)"
		fi
		temp_data+=("${del_time}|${file_size}|${target_name}|${ori_path}")
		local size_len=$(echo -n "$file_size" | wc -c)
		local name_len=$(echo -n "$target_name" | wc -c)
		
		# [ $size_len -gt $max_size ] && max_size=$size_len
		# [ $name_len -gt $max_name ] && max_name=$name_len
		[ $size_len -gt $max_size ] && max_size=$((size_len + 1))
		[ $name_len -gt $max_name ] && max_name=$((name_len + 1))
		# display+=("${del_time} ${file_size} ${target_name} ${ori_path}")
	done
	echo "总计 ${#result[@]}"
	# 设置大小和文件名的最小宽度
	# [ $max_size -lt 8 ] && max_size=5    # 大小列最小8个字符
	# [ $max_name -lt 10 ] && max_name=3  # 文件名列最小10个字符

	for data in "${temp_data[@]}"
	do
		IFS='|' read -r del_time file_size target_name ori_path <<< "$data"
		# 时间列直接原样输出，大小和文件名列对齐
		display+=("$del_time  $(printf "%-${max_size}s %-${max_name}s %s" "$file_size" "$target_name"  "$ori_path")")
	done

	PS3="选择文件(编号): "
	select item in "${display[@]}" "取消"
	do
		if [[ "$item" == "取消" ]]
		then
			break
		elif [[ -n "$item" ]]
		then
			local index=$((REPLY - 1))
			IFS='|' read -r target_name ori_path <<< "${result[$index]}"
			target_path="${trash}/${target_name}"

			if [ -d "${target_path}" ]
			then
				if ! ls -la  "${target_path}" | less
				then
					echo "错误: 无法显示文件内容: ${target_name}"
				fi
				continue
			else
				if ! less "$trash/$target_name"
				then
					echo "错误: 无法显示文件内容: ${target_name}"
				fi
				continue
			fi
		else
			echo "无效输入，请重新选择"
		fi
	done

	COLUMNS=$OLD_COLUMNS
}

d_mode(){

	echo "警告: 这将永久删除回收站中您的所有文件！"
    read -p "确认清空？(y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "操作已取消"
        return 0
    fi

	mapfile -t all_result < <(
	tac "$delInfo" )

	local filtered_result=()

	for item in "${all_result[@]}"; do
		IFS='|' read -r target_name ori_path <<< "$item"
		if check_owner "$trash/$target_name"
		then
			filtered_result+=("$item")
		fi
	done
	
	# 用过滤后的结果替换
	local result=("${filtered_result[@]}")

	if [ ${#result[@]} -eq 0 ]
	then
	 	echo "回收站已为空"
        return 0
	fi

	for dis in "${result[@]}"
	do
		IFS='|' read -r target_name ori_path <<< "${dis}"
		if rm -rf "$trash/$target_name"
			then
				sudo sed -i "\#${target_name}|${ori_path}#d" "$delInfo"
			else
				echo "错误: 删除文件失败: ${target_name}"
				continue
			fi
	done

}
while getopts "frRsd" opt; do
    case $opt in
        f) 
            if [ "$mode" != "default" ]; then
                echo "错误: -f, -R, -s, -d 参数不支持混用"
                exit 1
            fi
            mode="f" 
            ;;
        r) flag_r=true ;;
        R) 
            if [ "$mode" != "default" ]; then
                echo "错误: -f, -R, -s, -d 参数不支持混用"
                exit 1
            fi
            mode="R" 
            ;;
		s)	if [ "$mode" != "default" ]; then
                echo "错误: -f, -R, -s,-d 参数不支持混用"
                exit 1
            fi
            mode="s" 
            ;;
		d)	if [ "$mode" != "default" ]; then
                echo "错误: -f, -R, -s, -d 参数不支持混用"
                exit 1
            fi
            mode="d" 
            ;;
        *) 
            echo "未知的选项: -${opt}"
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

case "$mode" in
    R) R_mode "$@" ;;
    f) f_mode "$@" ;;
	s) s_mode ;;
	d) d_mode ;;
    default) default_mode "$@" ;;
esac
	
		
	

